@model IEnumerable<FSIT.Domain.Premises>

@{
    ViewData["Title"] = "Premises";
}
<h1>Premises</h1>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<p><a asp-action="Create" class="btn btn-success">+ Add Premises</a></p>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk Rating</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Address</td>
                <td>@item.Town</td>
                <td>
                    <span class="badge @(item.RiskRating == FSIT.Domain.RiskRating.High ? "bg-danger" : item.RiskRating == FSIT.Domain.RiskRating.Medium ? "bg-warning text-dark" : "bg-success")">
                        @item.RiskRating
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>